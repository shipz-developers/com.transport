# HTTP
SERVE_CONTENT=true
WEBSERVER_PORT=80
WEBSERVER_HOST=127.0.0.1

# Transport
TRANSPORT_MAX_PAYLOAD_CLIENT=2048    # Max inbound payload
TRANSPORT_MAX_PAYLOAD_SERVER=1048576 # Max outbound payload
TRANSPORT_MAX_RAW_CONNECTIONS=10240  # Max total app connection(s)
TRANSPORT_MAX_PPS_CLIENT=20          # Max packet/sec per client
TRANSPORT_MAX_PPS_IP=250             # Max packet/sec per remote IP
TRANSPORT_MAX_IP_CONNECTIONS=24      # Max connections per remote IP
TRANSPORT_BLOCK_IN_METACHARS="<,>,',\",;,--,%,#"  # Block inbound meta characters
TRANSPORT_BLOCK_IN_PATTERNS="script,select,drop,union,onerror,../,exec,eval,javascript:"  # Block inbound patterns
TRANSPORT_BLOCK_OUT_METACHARS="<,>" # outbound (resp)
TRANSPORT_BLOCK_OUT_PATTERNS="script,onerror" # outbound (resp)
TRANSPORT_LOG_CONNECTIONS=true    # Log connections
TRANSPORT_LOG_PACKETS=false       # Log packets
TRANSPORT_BEAT_INTERVAL_MS=2500   # Heartbeat interval (ping checks to each client)
TRANSPORT_BEAT_TIMEOUT_MS=30000   # Heartbeat timeout (no response from checks? terminate client)
TRANSPORT_CHALLENGE_TIMEOUT=1500  # In-Line instant challenge, ms depend(s) on packet transfer speeds
