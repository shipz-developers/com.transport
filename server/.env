# HTTP
SERVE_CONTENT=true
WEBSERVER_PORT=80
WEBSERVER_HOST=127.0.0.1

# Transport
TRANSPORT_MAX_PAYLOAD_CLIENT=2048
TRANSPORT_MAX_PAYLOAD_SERVER=1048576
TRANSPORT_MAX_RAW_CONNECTIONS=10240
TRANSPORT_MAX_PPS_CLIENT=20
TRANSPORT_MAX_PPS_IP=250
TRANSPORT_MAX_IP_CONNECTIONS=24
TRANSPORT_BLOCK_IN_METACHARS="<,>,',\",;,--,%,#"
TRANSPORT_BLOCK_IN_PATTERNS="script,select,drop,union,onerror,../,exec,eval,javascript:"
TRANSPORT_BLOCK_OUT_METACHARS="<,>"
TRANSPORT_BLOCK_OUT_PATTERNS="script,onerror"
TRANSPORT_LOG_CONNECTIONS=true
TRANSPORT_LOG_PACKETS=false
TRANSPORT_BEAT_INTERVAL_MS=2500
TRANSPORT_BEAT_TIMEOUT_MS=30000
TRANSPORT_CHALLENGE_TIMEOUT=1500
